window_size = 1000


def parse_args():
    parser = argparse.ArgumentParser(description="Traditional Machine Learning Methods Training")

    # Data parameters
    parser.add_argument("--data-type", type=str, default="LR-all", choices=["HR-mix1", "HR-single", "LR-mix2", "LR-single", "HR-all", "LR-all", "test"], help="Type of dataset to use")
    # windows PC    "E:/AFCI/Datasets/"
    # linux 9003 "/home/zzy/Datasets/"
    parser.add_argument("--data_path", type=str, default="E:/AFCI/Datasets/", help="Base path for dataset")

    # Training parameters
    parser.add_argument("--n-runs", type=int, default=5, help="Number of runs for statistical evaluation")

    return parser.parse_args()


######################训练######################
def train(input, label, sample_rate, n_runs=5):
    """
    训练传统机器学习模型，重复n_runs次并计算统计结果
    """
    trainer = ModelTrainer()

    # 存储所有运行的结果
    all_results = defaultdict(lambda: defaultdict(list))

    print(f"开始进行 {n_runs} 次训练和测试...\n")

    for run in range(n_runs):
        print(f"第 {run+1}/{n_runs} 次运行中...", end=" ")

        # 每次重新随机划分数据
        split_data_tuple = trainer.split_data(input, label)

        # 得到accuracy，FPR,FNR等数据
        results = trainer.train_and_evaluate(*split_data_tuple)

        # 收集所有模型的结果
        for model_name, metrics in results.items():
            for metric_name, metric_value in metrics.items():
                all_results[model_name][metric_name].append(metric_value)

        print("完成")

    # 计算均值和标准差
    print("\n" + "=" * 100)
    print("五次测试结果汇总（均值 ± 标准差，百分比格式）")
    print("=" * 100)

    # 获取所有模型和指标名称
    model_names = list(all_results.keys())
    if not model_names:
        print("没有结果可显示")
        return None, None

    # 获取所有指标名称（使用第一个模型的指标）
    metric_names = list(all_results[model_names[0]].keys())

    # 创建结果表格
    result_data = {}
    for metric_name in metric_names:
        result_data[metric_name] = {}
        for model_name in model_names:
            values = all_results[model_name][metric_name]
            mean_val = np.mean(values)
            std_val = np.std(values, ddof=1)  # 样本标准差
            # 百分比格式
            mean_percent = mean_val * 100
            std_percent = std_val * 100
            result_data[metric_name][model_name] = f"{mean_percent:.2f} ± {std_percent:.2f}"

    # 转换为DataFrame并转置，使模型为行，指标为列
    result_df = pd.DataFrame(result_data).T
    print("\n", result_df)

    # 输出详细数据（可选：显示5次具体数值）
    print("\n" + "=" * 100)
    print("详细数据（五次测试的具体数值）")
    print("=" * 100)

    for model_name in model_names:
        print(f"\n{model_name}:")
        for metric_name in metric_names:
            values = all_results[model_name][metric_name]
            mean_val = np.mean(values)
            std_val = np.std(values, ddof=1)
            print(f"  {metric_name}:")
            print(f"    五次结果: {[f'{v*100:.2f}' for v in values]}")  # 百分比显示
            print(f"    均值 ± 标准差: {mean_val*100:.2f} ± {std_val*100:.2f}")

    # 返回结果（用于后续处理）
    final_results = {}
    paper_format = {}
    for model_name, metrics_dict in all_results.items():
        final_results[model_name] = {}
        paper_format[model_name] = {}
        for metric_name, values in metrics_dict.items():
            mean_val = np.mean(values)
            std_val = np.std(values, ddof=1)
            final_results[model_name][metric_name] = {"mean": mean_val, "std": std_val, "values": values}
            mean_percent = mean_val * 100
            std_percent = std_val * 100
            paper_format[model_name][metric_name] = f"{mean_percent:.2f} ± {std_percent:.2f}"

    return final_results, paper_format


if __name__ == "__main__":
    args = parse_args()
    data_type, data_paths = get_data(args.data_type)
    logger = setup_logger(task_type="Train", data_type=args.data_type)

    logger.info("---------------------------数据集描述---------------------------")
    logger.info("训练数据集为{}".format(data_type))
    for data_path in data_paths:
        logger.info("Loading data from {}".format(data_path))

    # 数据读取
    logger.info("---------------------------数据读取---------------------------")
    start_time = datetime.now()
    U_combined, I_combined, label_combined, sample_rate = load_data_parallel(data_paths, args.data_path)
    end_time = datetime.now()
    elapsed_time = (end_time - start_time).total_seconds()
    logger.info(f"数据读取完成，总共用时{elapsed_time:.2f} 秒")

    # 预处理拼接后的数据
    logger.info("---------------------------数据预处理---------------------------")
    features_input = preprocess(I_combined.values, sample_rate)
    logger.info(f"预处理完成，特征维度: {features_input.shape}")

    # 训练模型
    logger.info("---------------------------开始训练传统机器学习模型---------------------------")
    train(features_input, label_combined, sample_rate, n_runs=args.n_runs)
